class UnionFind:
     def __init__(self, n):
          self.parent = [-1] * (n+1)
	  self.count = n

     def find(self, e):
          current = e
	  while self.parent[current] != -1:
	       current = self.current[current]
	  return current

     def union(self, e1, e2):
          root1 = self.find(e1)
	  root2 = self.find(e2)

	  if root1 != root2:
	       self.parent[root1] = root2
	       self.count -= 1
