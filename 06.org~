import heapq

class PriorityQ:
    def __init__(self):
        self.heap = [] 

    def is_empty(self):
        return len(self.heap) == 0

    def add(self, weight, u, v):
       heapq.heappush(self.heap, (weight, u, v))

    def remove(self):
       return heapq.heappop(self.heap)
#+end_src

