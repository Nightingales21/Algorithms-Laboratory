def is_unstable(m, w, currmatch, mprefs, wprefs):
    currw = currmatch[m]

    currm = ''
    for man, women in currmatch.items():
        if women == w:
            currm = man
            break

    m_wants_to_switch = mprefs[m].index(w) < mprefs[m].index(currw)
    w_wants_to_switch = wprefs[w].index(m) < wprefs[w].index(currm)

    return m_wants_to_switch and w_wants_to_switch

